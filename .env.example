# ── AdMob ──────────────────────────────────────────────────────────────
ADMOB_CLIENT_ID=your_oauth_client_id
ADMOB_CLIENT_SECRET=your_oauth_client_secret
ADMOB_REFRESH_TOKEN=your_refresh_token
ADMOB_PUBLISHER_ID=pub-XXXXXXXXXXXXXXXX   # e.g. pub-1234567890123456

# ── Google Ads ──────────────────────────────────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token
GOOGLE_ADS_CLIENT_ID=your_oauth_client_id
GOOGLE_ADS_CLIENT_SECRET=your_oauth_client_secret
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token
GOOGLE_ADS_CUSTOMER_ID=1234567890          # without dashes

# ── Database ────────────────────────────────────────────────────────────
# SQLite (default, no extra setup):
DATABASE_URL=sqlite:///./dashboard.db

# PostgreSQL (optional, recommended for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/admob_dashboard

# ── App ─────────────────────────────────────────────────────────────────
TIMEZONE=Asia/Kolkata
FETCH_HOUR=1          # Hour (0-23) when cron fetches previous day data
FETCH_MINUTE=0        # Minute of fetch
